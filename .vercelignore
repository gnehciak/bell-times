# Keep the deployment to just the app + its data + the SEO build script.
# (.vercelignore uses .gitignore syntax; build inputs must NOT be listed here.)

node_modules/
.git/
.vercel
.DS_Store
**/.DS_Store

# dev tooling / docs
.claude/
.codex/
.impeccable/
scratch/
*.md

# tools/ is dev-only — keep just what the SEO build needs (build script + app shell)
tools/*
!tools/build-pages.js
!tools/school-shell.html

# crawler image dumps & screenshots (real logos live in logos/)
/*.png
/*.jpg
/*.jpeg

# standalone crawl HTML dumps — canonical per-school pages live in /school/
/*.html
!index.html

# regenerated on Vercel by the build command
/school/
/sitemap.xml
/robots.txt

# generated Chrome extension — not part of the website deploy
/extension/
